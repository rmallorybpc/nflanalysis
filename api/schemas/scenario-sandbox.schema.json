{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmallorybpc.github.io/nflanalysis/schemas/scenario-sandbox.schema.json",
  "title": "Scenario Sandbox API Schema",
  "type": "object",
  "required": [
    "scenario_id",
    "team_id",
    "season",
    "period",
    "applied_moves",
    "baseline_estimates",
    "scenario_estimates",
    "delta_summary",
    "generated_at"
  ],
  "properties": {
    "scenario_id": {
      "type": "string"
    },
    "team_id": {
      "type": "string"
    },
    "season": {
      "type": "integer",
      "minimum": 2000
    },
    "period": {
      "type": "string"
    },
    "applied_moves": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ScenarioMove"
      }
    },
    "baseline_estimates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Estimate"
      }
    },
    "scenario_estimates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Estimate"
      }
    },
    "delta_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/DeltaPoint"
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "Interval": {
      "type": "object",
      "required": [
        "low",
        "high"
      ],
      "properties": {
        "low": {
          "type": "number"
        },
        "high": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "ScenarioMove": {
      "type": "object",
      "required": [
        "move_id",
        "player_id",
        "from_team_id",
        "to_team_id",
        "move_type",
        "action"
      ],
      "properties": {
        "move_id": {
          "type": "string"
        },
        "player_id": {
          "type": "string"
        },
        "from_team_id": {
          "type": "string"
        },
        "to_team_id": {
          "type": "string"
        },
        "move_type": {
          "type": "string",
          "enum": [
            "trade",
            "free_agency"
          ]
        },
        "action": {
          "type": "string",
          "enum": [
            "add",
            "remove"
          ]
        }
      },
      "additionalProperties": false
    },
    "Estimate": {
      "type": "object",
      "required": [
        "outcome_name",
        "mis_value",
        "mis_z",
        "median",
        "interval_50",
        "interval_90",
        "low_confidence_flag",
        "model_version",
        "data_version",
        "run_timestamp"
      ],
      "properties": {
        "outcome_name": {
          "type": "string",
          "enum": [
            "win_pct",
            "point_diff_per_game",
            "offensive_epa_per_play"
          ]
        },
        "mis_value": {
          "type": "number"
        },
        "mis_z": {
          "type": "number"
        },
        "median": {
          "type": "number"
        },
        "interval_50": {
          "$ref": "#/$defs/Interval"
        },
        "interval_90": {
          "$ref": "#/$defs/Interval"
        },
        "low_confidence_flag": {
          "type": "boolean"
        },
        "model_version": {
          "type": "string"
        },
        "data_version": {
          "type": "string"
        },
        "run_timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "DeltaPoint": {
      "type": "object",
      "required": [
        "outcome_name",
        "mis_delta",
        "direction",
        "interval_90_delta"
      ],
      "properties": {
        "outcome_name": {
          "type": "string",
          "enum": [
            "win_pct",
            "point_diff_per_game",
            "offensive_epa_per_play"
          ]
        },
        "mis_delta": {
          "type": "number"
        },
        "direction": {
          "type": "string",
          "enum": [
            "positive",
            "neutral",
            "negative"
          ]
        },
        "interval_90_delta": {
          "$ref": "#/$defs/Interval"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
