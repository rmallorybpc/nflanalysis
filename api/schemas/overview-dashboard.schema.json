{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmallorybpc.github.io/nflanalysis/schemas/overview-dashboard.schema.json",
  "title": "Overview Dashboard API Schema",
  "type": "object",
  "required": [
    "season",
    "generated_at",
    "scope",
    "cards",
    "charts"
  ],
  "properties": {
    "season": {
      "type": "integer",
      "minimum": 2000
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "$ref": "#/$defs/OverviewScope"
    },
    "cards": {
      "type": "object",
      "required": [
        "top_positive_team",
        "top_negative_team",
        "league_net_mis",
        "high_confidence_share"
      ],
      "properties": {
        "top_positive_team": {
           "$ref": "#/$defs/TeamImpactCard"
        },
        "top_negative_team": {
           "$ref": "#/$defs/TeamImpactCard"
        },
        "league_net_mis": {
          "type": "number"
        },
        "high_confidence_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "charts": {
      "type": "object",
      "required": [
        "league_ranking",
        "outcome_distribution",
        "season_coverage",
        "geography_impact_profile",
        "geography_sensitivity_profiles"
      ],
      "properties": {
        "league_ranking": {
          "type": "array",
          "minItems": 1,
          "items": {
              "$ref": "#/$defs/TeamRankingPoint"
          }
        },
        "outcome_distribution": {
          "type": "array",
          "minItems": 1,
          "items": {
              "$ref": "#/$defs/OutcomeDistributionPoint"
          }
        },
        "season_coverage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/SeasonCoveragePoint"
          }
        },
        "geography_impact_profile": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GeographyImpactPoint"
          }
        },
        "geography_sensitivity_profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GeographySensitivityProfile"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "Interval": {
      "type": "object",
      "required": [
        "low",
        "high"
      ],
      "properties": {
        "low": {
          "type": "number"
        },
        "high": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "TeamImpactCard": {
      "type": "object",
      "required": [
        "team_id",
        "outcome_name",
        "mis_value",
        "mis_z",
        "interval_90",
        "low_confidence_flag",
        "model_version",
        "data_version"
      ],
      "properties": {
        "team_id": {
          "type": "string"
        },
        "outcome_name": {
          "type": "string",
          "enum": [
            "win_pct",
            "point_diff_per_game",
            "offensive_epa_per_play"
          ]
        },
        "mis_value": {
          "type": "number"
        },
        "mis_z": {
          "type": "number"
        },
        "interval_90": {
            "$ref": "#/$defs/Interval"
        },
        "low_confidence_flag": {
          "type": "boolean"
        },
        "model_version": {
          "type": "string"
        },
        "data_version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "TeamRankingPoint": {
      "type": "object",
      "required": [
        "rank",
        "team_id",
        "mis_value",
        "mis_z"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "team_id": {
          "type": "string"
        },
        "mis_value": {
          "type": "number"
        },
        "mis_z": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "OutcomeDistributionPoint": {
      "type": "object",
      "required": [
        "outcome_name",
        "bin_label",
        "count"
      ],
      "properties": {
        "outcome_name": {
          "type": "string",
          "enum": [
            "win_pct",
            "point_diff_per_game",
            "offensive_epa_per_play"
          ]
        },
        "bin_label": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "OverviewScope": {
      "type": "object",
      "required": [
        "season_range",
        "season_count",
        "team_count",
        "included_move_types",
        "move_type_counts",
        "outcomes",
        "geography_dimensions",
        "geography_data_quality",
        "validation_diagnostics",
        "geography_claim_policy"
      ],
      "properties": {
        "season_range": {
          "type": "object",
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "integer"
            },
            "end": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "season_count": {
          "type": "integer",
          "minimum": 1
        },
        "team_count": {
          "type": "integer",
          "minimum": 1
        },
        "included_move_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["trade", "free_agency"]
          }
        },
        "move_type_counts": {
          "type": "object",
          "required": [
            "trade",
            "free_agency"
          ],
          "properties": {
            "trade": {
              "type": "integer",
              "minimum": 0
            },
            "free_agency": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "outcomes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "win_pct",
              "point_diff_per_game",
              "offensive_epa_per_play"
            ]
          }
        },
        "geography_dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["team", "division", "conference"]
          }
        },
        "geography_data_quality": {
          "$ref": "#/$defs/GeographyDataQuality"
        },
        "validation_diagnostics": {
          "$ref": "#/$defs/ValidationDiagnostics"
        },
        "geography_claim_policy": {
          "$ref": "#/$defs/GeographyClaimPolicy"
        }
      },
      "additionalProperties": false
    },
    "SeasonCoveragePoint": {
      "type": "object",
      "required": [
        "season",
        "latest_week",
        "team_count"
      ],
      "properties": {
        "season": {
          "type": "integer"
        },
        "latest_week": {
          "type": "integer",
          "minimum": 1
        },
        "team_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "GeographyImpactPoint": {
      "type": "object",
      "required": [
        "move_scope",
        "outcome_name",
        "move_count",
        "avg_abs_impact"
      ],
      "properties": {
        "move_scope": {
          "type": "string",
          "enum": [
            "same_division",
            "cross_division",
            "cross_conference"
          ]
        },
        "outcome_name": {
          "type": "string",
          "enum": [
            "win_pct",
            "point_diff_per_game",
            "offensive_epa_per_play"
          ]
        },
        "move_count": {
          "type": "integer",
          "minimum": 0
        },
        "avg_abs_impact": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "GeographyDataQuality": {
      "type": "object",
      "required": [
        "total_events",
        "unknown_scope_events",
        "unknown_scope_share",
        "missing_from_team_events",
        "destination_only_events"
      ],
      "properties": {
        "total_events": {
          "type": "integer",
          "minimum": 0
        },
        "unknown_scope_events": {
          "type": "integer",
          "minimum": 0
        },
        "unknown_scope_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "missing_from_team_events": {
          "type": "integer",
          "minimum": 0
        },
        "destination_only_events": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "GeographyModeSummary": {
      "type": "object",
      "required": [
        "strongest_scope",
        "strongest_avg_abs_impact",
        "strongest_move_count",
        "runner_up_scope",
        "runner_up_avg_abs_impact",
        "placebo_win_pct_p_value",
        "robustness_flag",
        "robustness_reason"
      ],
      "properties": {
        "strongest_scope": {
          "type": "string"
        },
        "strongest_avg_abs_impact": {
          "type": "number",
          "minimum": 0
        },
        "strongest_move_count": {
          "type": "integer",
          "minimum": 0
        },
        "runner_up_scope": {
          "type": "string"
        },
        "runner_up_avg_abs_impact": {
          "type": "number",
          "minimum": 0
        },
        "placebo_win_pct_p_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "robustness_flag": {
          "type": "boolean"
        },
        "robustness_reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "GeographySensitivityProfile": {
      "type": "object",
      "required": [
        "mode",
        "label",
        "included_event_count",
        "excluded_event_count",
        "points",
        "win_pct_summary"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["all_events", "known_scope_only", "trades_only"]
        },
        "label": {
          "type": "string"
        },
        "included_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "excluded_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GeographyImpactPoint"
          }
        },
        "win_pct_summary": {
          "$ref": "#/$defs/GeographyModeSummary"
        }
      },
      "additionalProperties": false
    },
    "ValidationDiagnostics": {
      "type": "object",
      "required": [
        "available",
        "placebo_win_pct_p_value",
        "placebo_iterations",
        "scope_mode_placebo_win_pct_p_values",
        "scope_mode_placebo_available",
        "scope_mode_placebo_iterations",
        "generated_at"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "placebo_win_pct_p_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "placebo_iterations": {
          "type": "integer",
          "minimum": 0
        },
        "scope_mode_placebo_win_pct_p_values": {
          "$ref": "#/$defs/ScopeModeNumericMap"
        },
        "scope_mode_placebo_available": {
          "$ref": "#/$defs/ScopeModeBooleanMap"
        },
        "scope_mode_placebo_iterations": {
          "$ref": "#/$defs/ScopeModeIntegerMap"
        },
        "generated_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ScopeModeNumericMap": {
      "type": "object",
      "required": [
        "all_events",
        "known_scope_only",
        "trades_only"
      ],
      "properties": {
        "all_events": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "known_scope_only": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "trades_only": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "ScopeModeBooleanMap": {
      "type": "object",
      "required": [
        "all_events",
        "known_scope_only",
        "trades_only"
      ],
      "properties": {
        "all_events": {
          "type": "boolean"
        },
        "known_scope_only": {
          "type": "boolean"
        },
        "trades_only": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ScopeModeIntegerMap": {
      "type": "object",
      "required": [
        "all_events",
        "known_scope_only",
        "trades_only"
      ],
      "properties": {
        "all_events": {
          "type": "integer",
          "minimum": 0
        },
        "known_scope_only": {
          "type": "integer",
          "minimum": 0
        },
        "trades_only": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "GeographyClaimPolicy": {
      "type": "object",
      "required": [
        "can_make_strong_claim",
        "reasons",
        "min_robust_move_count",
        "max_unknown_scope_share",
        "max_placebo_p_value"
      ],
      "properties": {
        "can_make_strong_claim": {
          "type": "boolean"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "min_robust_move_count": {
          "type": "integer",
          "minimum": 1
        },
        "max_unknown_scope_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_placebo_p_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
