{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmallorybpc.github.io/nflanalysis/schemas/overview-dashboard.schema.json",
  "title": "Overview Dashboard API Schema",
  "type": "object",
  "required": [
    "season",
    "generated_at",
    "cards",
    "charts"
  ],
  "properties": {
    "season": {
      "type": "integer",
      "minimum": 2000
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "cards": {
      "type": "object",
      "required": [
        "top_positive_team",
        "top_negative_team",
        "league_net_mis",
        "high_confidence_share"
      ],
      "properties": {
        "top_positive_team": {
           "$ref": "#/$defs/TeamImpactCard"
        },
        "top_negative_team": {
           "$ref": "#/$defs/TeamImpactCard"
        },
        "league_net_mis": {
          "type": "number"
        },
        "high_confidence_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "charts": {
      "type": "object",
      "required": [
        "league_ranking",
        "outcome_distribution"
      ],
      "properties": {
        "league_ranking": {
          "type": "array",
          "minItems": 1,
          "items": {
              "$ref": "#/$defs/TeamRankingPoint"
          }
        },
        "outcome_distribution": {
          "type": "array",
          "minItems": 1,
          "items": {
              "$ref": "#/$defs/OutcomeDistributionPoint"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "Interval": {
      "type": "object",
      "required": [
        "low",
        "high"
      ],
      "properties": {
        "low": {
          "type": "number"
        },
        "high": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "TeamImpactCard": {
      "type": "object",
      "required": [
        "team_id",
        "outcome_name",
        "mis_value",
        "mis_z",
        "interval_90",
        "low_confidence_flag",
        "model_version",
        "data_version"
      ],
      "properties": {
        "team_id": {
          "type": "string"
        },
        "outcome_name": {
          "type": "string",
          "enum": [
            "win_pct",
            "point_diff_per_game",
            "offensive_epa_per_play"
          ]
        },
        "mis_value": {
          "type": "number"
        },
        "mis_z": {
          "type": "number"
        },
        "interval_90": {
            "$ref": "#/$defs/Interval"
        },
        "low_confidence_flag": {
          "type": "boolean"
        },
        "model_version": {
          "type": "string"
        },
        "data_version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "TeamRankingPoint": {
      "type": "object",
      "required": [
        "rank",
        "team_id",
        "mis_value",
        "mis_z"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "team_id": {
          "type": "string"
        },
        "mis_value": {
          "type": "number"
        },
        "mis_z": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "OutcomeDistributionPoint": {
      "type": "object",
      "required": [
        "outcome_name",
        "bin_label",
        "count"
      ],
      "properties": {
        "outcome_name": {
          "type": "string",
          "enum": [
            "win_pct",
            "point_diff_per_game",
            "offensive_epa_per_play"
          ]
        },
        "bin_label": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
